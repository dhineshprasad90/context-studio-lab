{
  "@context": {
    "sro": "http://example.org/sro#",
    "schema": "http://schema.org/",
    "id": "@id",
    "type": "@type",
    "name": "schema:name",
    "description": "schema:description",
    "attributes": "sro:attributes",
    "identityKey": "sro:identityKey",
    "humanRef": "sro:humanRef",
    "invariant": "sro:invariant",
    "hasState": {
      "@id": "sro:hasState",
      "@type": "@id"
    },
    "initialState": {
      "@id": "sro:initialState",
      "@type": "@id"
    },
    "terminalStates": {
      "@id": "sro:terminalStates",
      "@type": "@id"
    },
    "relatesTo": {
      "@id": "sro:relatesTo",
      "@type": "@id"
    },
    "emitsEvent": {
      "@id": "sro:emitsEvent",
      "@type": "@id"
    },
    "from": {
      "@id": "sro:from",
      "@type": "@id"
    },
    "to": {
      "@id": "sro:to",
      "@type": "@id"
    },
    "precondition": "sro:precondition",
    "postcondition": "sro:postcondition",
    "Entity": "sro:Entity",
    "Operation": "sro:Operation",
    "State": "sro:State"
  },
  "@graph": [
    {
      "id": "sro:Requirement",
      "type": "Entity",
      "name": "Requirement",
      "description": "A documented need or constraint for a software system",
      "identityKey": "requirementId: UUID",
      "humanRef": "requirementCode",
      "attributes": {
        "requirementId": "string",
        "requirementCode": "string",
        "name": "string",
        "description": "string",
        "rationale": "string|null",
        "acceptanceCriteria": "string|null",
        "priority": "MUST|SHOULD|COULD|WONT",
        "status": "DRAFT|APPROVED|IMPLEMENTED|VERIFIED|REJECTED",
        "version": "string",
        "createdDate": "dateTime",
        "modifiedDate": "dateTime"
      },
      "invariant": [
        "requirementCode must be unique",
        "priority must be one of MoSCoW values",
        "A requirement must have at least one stakeholder source",
        "version must follow semantic versioning"
      ],
      "hasState": [
        "sro:RequirementDraft",
        "sro:RequirementApproved",
        "sro:RequirementImplemented",
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ],
      "initialState": "sro:RequirementDraft",
      "terminalStates": [
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ],
      "relatesTo": [
        "sro:Stakeholder",
        "sro:Goal",
        "sro:SystemComponent",
        "sro:TestCase",
        "sro:UseCase"
      ],
      "emitsEvent": [
        "sro:RequirementCreated",
        "sro:RequirementApproved",
        "sro:RequirementImplemented",
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ]
    },
    {
      "id": "sro:FunctionalRequirement",
      "type": "Entity",
      "name": "FunctionalRequirement",
      "description": "Describes a specific behavior or function of the system",
      "identityKey": "requirementId: UUID",
      "humanRef": "requirementCode",
      "attributes": {
        "requirementId": "string",
        "requirementCode": "string",
        "name": "string",
        "description": "string",
        "rationale": "string|null",
        "acceptanceCriteria": "string",
        "priority": "MUST|SHOULD|COULD|WONT",
        "status": "DRAFT|APPROVED|IMPLEMENTED|VERIFIED|REJECTED",
        "inputConditions": "string|null",
        "outputConditions": "string|null",
        "businessRule": "string|null"
      },
      "invariant": [
        "Must define clear acceptance criteria",
        "Must specify expected system behavior",
        "acceptanceCriteria cannot be null",
        "Must have at least one use case"
      ],
      "hasState": [
        "sro:RequirementDraft",
        "sro:RequirementApproved",
        "sro:RequirementImplemented",
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ],
      "initialState": "sro:RequirementDraft",
      "terminalStates": [
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ],
      "relatesTo": [
        "sro:Stakeholder",
        "sro:Goal",
        "sro:SystemComponent",
        "sro:TestCase",
        "sro:UseCase"
      ]
    },
    {
      "id": "sro:NonFunctionalRequirement",
      "type": "Entity",
      "name": "NonFunctionalRequirement",
      "description": "Describes a quality attribute such as performance, security, or usability",
      "identityKey": "requirementId: UUID",
      "humanRef": "requirementCode",
      "attributes": {
        "requirementId": "string",
        "requirementCode": "string",
        "name": "string",
        "description": "string",
        "qualityAttribute": "PERFORMANCE|SECURITY|USABILITY|RELIABILITY|MAINTAINABILITY|PORTABILITY|SCALABILITY",
        "priority": "MUST|SHOULD|COULD|WONT",
        "status": "DRAFT|APPROVED|IMPLEMENTED|VERIFIED|REJECTED",
        "measurementCriteria": "string",
        "targetValue": "string|null"
      },
      "invariant": [
        "Must specify measurable quality criteria",
        "qualityAttribute must be one of defined values",
        "measurementCriteria must be quantifiable",
        "targetValue should be defined for verification"
      ],
      "hasState": [
        "sro:RequirementDraft",
        "sro:RequirementApproved",
        "sro:RequirementImplemented",
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ],
      "initialState": "sro:RequirementDraft",
      "terminalStates": [
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ],
      "relatesTo": [
        "sro:Stakeholder",
        "sro:Goal",
        "sro:SystemComponent",
        "sro:TestCase"
      ]
    },
    {
      "id": "sro:SecurityRequirement",
      "type": "Entity",
      "name": "SecurityRequirement",
      "description": "Specifies security constraints, protections, and compliance needs",
      "identityKey": "requirementId: UUID",
      "humanRef": "requirementCode",
      "attributes": {
        "requirementId": "string",
        "requirementCode": "string",
        "name": "string",
        "description": "string",
        "securityCategory": "AUTHENTICATION|AUTHORIZATION|ENCRYPTION|AUDIT|COMPLIANCE|DATA_PROTECTION",
        "priority": "MUST|SHOULD|COULD|WONT",
        "status": "DRAFT|APPROVED|IMPLEMENTED|VERIFIED|REJECTED",
        "threatModel": "string|null",
        "complianceStandard": "string|null",
        "riskLevel": "CRITICAL|HIGH|MEDIUM|LOW"
      },
      "invariant": [
        "securityCategory must be one of defined values",
        "CRITICAL and HIGH risk requirements must have priority MUST",
        "Must specify threat model or compliance standard",
        "Must have associated security test cases"
      ],
      "hasState": [
        "sro:RequirementDraft",
        "sro:RequirementApproved",
        "sro:RequirementImplemented",
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ],
      "initialState": "sro:RequirementDraft",
      "terminalStates": [
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ],
      "relatesTo": [
        "sro:Stakeholder",
        "sro:Goal",
        "sro:SystemComponent",
        "sro:TestCase",
        "sro:SecurityRequirement"
      ]
    },
    {
      "id": "sro:PerformanceRequirement",
      "type": "Entity",
      "name": "PerformanceRequirement",
      "description": "Specifies performance criteria including response time, throughput, and resource usage",
      "identityKey": "requirementId: UUID",
      "humanRef": "requirementCode",
      "attributes": {
        "requirementId": "string",
        "requirementCode": "string",
        "name": "string",
        "description": "string",
        "performanceMetric": "RESPONSE_TIME|THROUGHPUT|LATENCY|RESOURCE_USAGE|SCALABILITY|AVAILABILITY",
        "priority": "MUST|SHOULD|COULD|WONT",
        "status": "DRAFT|APPROVED|IMPLEMENTED|VERIFIED|REJECTED",
        "targetValue": "string",
        "measurementUnit": "string",
        "loadCondition": "string|null"
      },
      "invariant": [
        "performanceMetric must be one of defined values",
        "targetValue must be quantifiable",
        "measurementUnit must be specified",
        "Must have performance test cases for verification"
      ],
      "hasState": [
        "sro:RequirementDraft",
        "sro:RequirementApproved",
        "sro:RequirementImplemented",
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ],
      "initialState": "sro:RequirementDraft",
      "terminalStates": [
        "sro:RequirementVerified",
        "sro:RequirementRejected"
      ],
      "relatesTo": [
        "sro:Stakeholder",
        "sro:Goal",
        "sro:SystemComponent",
        "sro:TestCase"
      ]
    },
    {
      "id": "sro:Stakeholder",
      "type": "Entity",
      "name": "Stakeholder",
      "description": "An individual or group with interest in the system requirements",
      "identityKey": "stakeholderId: UUID",
      "humanRef": "stakeholderName",
      "attributes": {
        "stakeholderId": "string",
        "stakeholderName": "string",
        "role": "END_USER|CUSTOMER|DEVELOPER|PROJECT_MANAGER|BUSINESS_ANALYST|TESTER|ARCHITECT",
        "organization": "string|null",
        "contactInfo": "string|null",
        "influence": "HIGH|MEDIUM|LOW",
        "interest": "HIGH|MEDIUM|LOW"
      },
      "invariant": [
        "stakeholderName must be unique within organization",
        "role must be defined",
        "At least one contact method must be provided"
      ],
      "relatesTo": [
        "sro:Requirement",
        "sro:Goal",
        "sro:UseCase"
      ]
    },
    {
      "id": "sro:Goal",
      "type": "Entity",
      "name": "Goal",
      "description": "A high-level objective that requirements refine and support",
      "identityKey": "goalId: UUID",
      "humanRef": "goalName",
      "attributes": {
        "goalId": "string",
        "goalName": "string",
        "description": "string",
        "goalType": "BUSINESS|USER|SYSTEM|TECHNICAL",
        "priority": "HIGH|MEDIUM|LOW",
        "status": "PROPOSED|ACCEPTED|ACHIEVED|ABANDONED",
        "successCriteria": "string|null"
      },
      "invariant": [
        "goalName must be unique",
        "A goal must be refined by at least one requirement",
        "goalType must be one of defined values",
        "successCriteria should be measurable"
      ],
      "hasState": [
        "sro:GoalProposed",
        "sro:GoalAccepted",
        "sro:GoalAchieved",
        "sro:GoalAbandoned"
      ],
      "initialState": "sro:GoalProposed",
      "terminalStates": [
        "sro:GoalAchieved",
        "sro:GoalAbandoned"
      ],
      "relatesTo": [
        "sro:Requirement",
        "sro:Stakeholder",
        "sro:Goal"
      ]
    },
    {
      "id": "sro:UseCase",
      "type": "Entity",
      "name": "UseCase",
      "description": "Describes how actors interact with the system to achieve specific goals",
      "identityKey": "useCaseId: UUID",
      "humanRef": "useCaseCode",
      "attributes": {
        "useCaseId": "string",
        "useCaseCode": "string",
        "name": "string",
        "description": "string",
        "precondition": "string|null",
        "postcondition": "string|null",
        "mainFlow": "string",
        "alternativeFlows": "string|null",
        "exceptionFlows": "string|null",
        "priority": "HIGH|MEDIUM|LOW"
      },
      "invariant": [
        "useCaseCode must be unique",
        "Must have at least one actor",
        "mainFlow must be defined",
        "Must realize at least one functional requirement"
      ],
      "relatesTo": [
        "sro:FunctionalRequirement",
        "sro:Actor",
        "sro:Scenario",
        "sro:TestCase",
        "sro:UseCase"
      ]
    },
    {
      "id": "sro:Actor",
      "type": "Entity",
      "name": "Actor",
      "description": "A role played by a user or external system when interacting with the system",
      "identityKey": "actorId: UUID",
      "humanRef": "actorName",
      "attributes": {
        "actorId": "string",
        "actorName": "string",
        "description": "string",
        "actorType": "PRIMARY|SECONDARY|EXTERNAL_SYSTEM",
        "responsibilities": "string|null"
      },
      "invariant": [
        "actorName must be unique",
        "actorType must be one of defined values",
        "Must participate in at least one use case"
      ],
      "relatesTo": [
        "sro:UseCase",
        "sro:Stakeholder"
      ]
    },
    {
      "id": "sro:Scenario",
      "type": "Entity",
      "name": "Scenario",
      "description": "A specific sequence of actions and interactions in a use case",
      "identityKey": "scenarioId: UUID",
      "humanRef": "scenarioName",
      "attributes": {
        "scenarioId": "string",
        "scenarioName": "string",
        "description": "string",
        "scenarioType": "MAIN|ALTERNATIVE|EXCEPTION",
        "steps": "string",
        "expectedOutcome": "string"
      },
      "invariant": [
        "scenarioName must be unique within use case",
        "scenarioType must be one of defined values",
        "steps must be ordered and numbered"
      ],
      "relatesTo": [
        "sro:UseCase",
        "sro:TestCase"
      ]
    },
    {
      "id": "sro:SystemComponent",
      "type": "Entity",
      "name": "SystemComponent",
      "description": "A module or component that realizes requirements",
      "identityKey": "componentId: UUID",
      "humanRef": "componentName",
      "attributes": {
        "componentId": "string",
        "componentName": "string",
        "description": "string|null",
        "componentType": "MODULE|SERVICE|LIBRARY|DATABASE|INTERFACE",
        "technology": "string|null",
        "version": "string|null"
      },
      "invariant": [
        "componentName must be unique",
        "componentType must be one of defined values",
        "Must realize at least one requirement"
      ],
      "relatesTo": [
        "sro:Requirement",
        "sro:SystemComponent"
      ]
    },
    {
      "id": "sro:TestCase",
      "type": "Entity",
      "name": "TestCase",
      "description": "A test that verifies requirement implementation",
      "identityKey": "testCaseId: UUID",
      "humanRef": "testCaseCode",
      "attributes": {
        "testCaseId": "string",
        "testCaseCode": "string",
        "name": "string",
        "description": "string",
        "testType": "UNIT|INTEGRATION|SYSTEM|ACCEPTANCE|PERFORMANCE|SECURITY",
        "status": "PENDING|PASSED|FAILED|BLOCKED|SKIPPED",
        "precondition": "string|null",
        "testSteps": "string",
        "testInput": "string|null",
        "expectedOutput": "string",
        "actualOutput": "string|null",
        "priority": "HIGH|MEDIUM|LOW"
      },
      "invariant": [
        "testCaseCode must be unique",
        "Must verify at least one requirement",
        "testType must be one of defined values",
        "testSteps must be clearly defined",
        "expectedOutput must be specified"
      ],
      "hasState": [
        "sro:TestPending",
        "sro:TestPassed",
        "sro:TestFailed",
        "sro:TestBlocked",
        "sro:TestSkipped"
      ],
      "initialState": "sro:TestPending",
      "terminalStates": [
        "sro:TestPassed",
        "sro:TestFailed",
        "sro:TestSkipped"
      ],
      "relatesTo": [
        "sro:Requirement",
        "sro:UseCase",
        "sro:Scenario",
        "sro:TestCase"
      ]
    },
    {
      "id": "sro:HasSource",
      "type": "Operation",
      "name": "HasSource",
      "description": "Links a requirement to its originating stakeholder",
      "from": "sro:Requirement",
      "to": "sro:Stakeholder",
      "precondition": [
        "Requirement must exist",
        "Stakeholder must exist",
        "Stakeholder must have appropriate role"
      ],
      "postcondition": [
        "Requirement is associated with at least one Stakeholder",
        "Stakeholder is recorded as source of the requirement",
        "Traceability link is established"
      ]
    },
    {
      "id": "sro:Refines",
      "type": "Operation",
      "name": "Refines",
      "description": "Establishes that a requirement refines a higher-level goal",
      "from": "sro:Requirement",
      "to": "sro:Goal",
      "precondition": [
        "Requirement must exist",
        "Goal must exist",
        "Goal must be in ACCEPTED state"
      ],
      "postcondition": [
        "Requirement contributes to achieving the Goal",
        "Goal is refined by one or more Requirements",
        "Refinement relationship is bidirectional"
      ]
    },
    {
      "id": "sro:DependsOn",
      "type": "Operation",
      "name": "DependsOn",
      "description": "Defines dependency between requirements",
      "from": "sro:Requirement",
      "to": "sro:Requirement",
      "precondition": [
        "Both requirements must exist",
        "No circular dependencies allowed",
        "Dependency must be justified"
      ],
      "postcondition": [
        "Dependent requirement cannot be implemented before prerequisite",
        "Dependency relationship is recorded",
        "Dependency graph remains acyclic"
      ]
    },
    {
      "id": "sro:ConflictsWith",
      "type": "Operation",
      "name": "ConflictsWith",
      "description": "Identifies conflicting requirements that need resolution",
      "from": "sro:Requirement",
      "to": "sro:Requirement",
      "precondition": [
        "Both requirements must exist",
        "Conflict must be documented with rationale",
        "Conflict type must be specified"
      ],
      "postcondition": [
        "Conflict is recorded for resolution",
        "Requirements cannot both be implemented without resolution",
        "Stakeholders are notified of conflict"
      ]
    },
    {
      "id": "sro:RealizedBy",
      "type": "Operation",
      "name": "RealizedBy",
      "description": "Links a requirement to the system component that implements it",
      "from": "sro:Requirement",
      "to": "sro:SystemComponent",
      "precondition": [
        "Requirement must be in APPROVED or IMPLEMENTED state",
        "SystemComponent must exist",
        "Component must have capability to realize requirement"
      ],
      "postcondition": [
        "Requirement is implemented by SystemComponent",
        "SystemComponent realizes one or more Requirements",
        "Implementation traceability is established"
      ]
    },
    {
      "id": "sro:VerifiedBy",
      "type": "Operation",
      "name": "VerifiedBy",
      "description": "Associates a requirement with test cases that verify its implementation",
      "from": "sro:Requirement",
      "to": "sro:TestCase",
      "precondition": [
        "Requirement must be in IMPLEMENTED state",
        "TestCase must exist",
        "TestCase must be appropriate for requirement type"
      ],
      "postcondition": [
        "Requirement is verified by one or more TestCases",
        "TestCase validates the Requirement implementation",
        "Verification coverage is tracked"
      ]
    },
    {
      "id": "sro:Realizes",
      "type": "Operation",
      "name": "Realizes",
      "description": "Links a use case to the functional requirements it implements",
      "from": "sro:UseCase",
      "to": "sro:FunctionalRequirement",
      "precondition": [
        "UseCase must exist",
        "FunctionalRequirement must exist",
        "UseCase must describe behavior specified in requirement"
      ],
      "postcondition": [
        "UseCase realizes one or more FunctionalRequirements",
        "FunctionalRequirement is realized by one or more UseCases",
        "Realization traceability is established"
      ]
    },
    {
      "id": "sro:HasActor",
      "type": "Operation",
      "name": "HasActor",
      "description": "Associates a use case with actors who participate in it",
      "from": "sro:UseCase",
      "to": "sro:Actor",
      "precondition": [
        "UseCase must exist",
        "Actor must exist",
        "Actor role must be defined"
      ],
      "postcondition": [
        "UseCase has one or more Actors",
        "Actor participates in one or more UseCases",
        "Actor responsibilities are documented"
      ]
    },
    {
      "id": "sro:HasScenario",
      "type": "Operation",
      "name": "HasScenario",
      "description": "Associates a use case with its execution scenarios",
      "from": "sro:UseCase",
      "to": "sro:Scenario",
      "precondition": [
        "UseCase must exist",
        "Scenario must exist",
        "Scenario must be consistent with use case"
      ],
      "postcondition": [
        "UseCase has one or more Scenarios",
        "Scenario belongs to exactly one UseCase",
        "At least one main scenario must exist"
      ]
    },
    {
      "id": "sro:Includes",
      "type": "Operation",
      "name": "Includes",
      "description": "Indicates that one use case includes the behavior of another use case",
      "from": "sro:UseCase",
      "to": "sro:UseCase",
      "precondition": [
        "Both use cases must exist",
        "Included use case must be reusable",
        "No circular inclusion allowed"
      ],
      "postcondition": [
        "Including use case incorporates included use case behavior",
        "Included use case can be reused by multiple use cases",
        "Inclusion relationship is documented"
      ]
    },
    {
      "id": "sro:Extends",
      "type": "Operation",
      "name": "Extends",
      "description": "Indicates that one use case extends another under certain conditions",
      "from": "sro:UseCase",
      "to": "sro:UseCase",
      "precondition": [
        "Both use cases must exist",
        "Extension point must be defined in base use case",
        "Extension condition must be specified"
      ],
      "postcondition": [
        "Extending use case adds behavior to base use case",
        "Extension is conditional",
        "Base use case remains complete without extension"
      ]
    },
    {
      "id": "sro:Supports",
      "type": "Operation",
      "name": "Supports",
      "description": "Indicates that one goal supports achieving another goal",
      "from": "sro:Goal",
      "to": "sro:Goal",
      "precondition": [
        "Both goals must exist",
        "Support relationship must be justified",
        "No circular support allowed"
      ],
      "postcondition": [
        "Supporting goal contributes to supported goal",
        "Goal hierarchy is maintained",
        "Support relationship is documented"
      ]
    },
    {
      "id": "sro:Obstructs",
      "type": "Operation",
      "name": "Obstructs",
      "description": "Indicates that one goal hinders achieving another goal",
      "from": "sro:Goal",
      "to": "sro:Goal",
      "precondition": [
        "Both goals must exist",
        "Obstruction must be documented",
        "Conflict resolution strategy must be defined"
      ],
      "postcondition": [
        "Obstruction is recorded for resolution",
        "Goals cannot both be fully achieved without trade-offs",
        "Stakeholders are notified of goal conflict"
      ]
    },
    {
      "id": "sro:Mitigates",
      "type": "Operation",
      "name": "Mitigates",
      "description": "Indicates that a security requirement mitigates risks from another security requirement",
      "from": "sro:SecurityRequirement",
      "to": "sro:SecurityRequirement",
      "precondition": [
        "Both security requirements must exist",
        "Mitigation strategy must be defined",
        "Risk level must be assessed"
      ],
      "postcondition": [
        "Mitigating requirement reduces risk of mitigated requirement",
        "Mitigation relationship is documented",
        "Risk reduction is quantified"
      ]
    },
    {
      "id": "sro:Impacts",
      "type": "Operation",
      "name": "Impacts",
      "description": "Indicates that changes to one requirement may affect another",
      "from": "sro:Requirement",
      "to": "sro:Requirement",
      "precondition": [
        "Both requirements must exist",
        "Impact type must be specified",
        "Impact severity must be assessed"
      ],
      "postcondition": [
        "Impact relationship is recorded",
        "Change management considers impacts",
        "Affected requirements are tracked"
      ]
    },
    {
      "id": "sro:PrerequisiteTest",
      "type": "Operation",
      "name": "PrerequisiteTest",
      "description": "Indicates that one test case must be executed before another",
      "from": "sro:TestCase",
      "to": "sro:TestCase",
      "precondition": [
        "Both test cases must exist",
        "Prerequisite relationship must be justified",
        "No circular dependencies allowed"
      ],
      "postcondition": [
        "Dependent test cannot execute until prerequisite passes",
        "Test execution order is enforced",
        "Test dependency graph is maintained"
      ]
    },
    {
      "id": "sro:RequirementDraft",
      "type": "State",
