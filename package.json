  "license": "Apache License 2.0",
  "bugs": {
    "url": "https://github.com/context-studio/context-studio-lab/issues"
  },
  "homepage": "https://github.com/context-studio/context-studio-lab#readme",
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-xwalk": "github:adobe-rnd/eslint-plugin-xwalk",
    "husky": "^9.1.1",
    "merge-json-cli": "^1.0.4",
    "npm-run-all": "^4.1.5",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
